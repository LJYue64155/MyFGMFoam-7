{
  "tasks": [
    {
      "type": "shell",
      "label": "of-7: opt build MyFGMFoam",
      "command": [
        "cd ${workspaceFolder}/applications/MyFGMFoam/src;",
        "source /OpenFOAM/of7/OpenFOAM-7/etc/bashrc WM_NCOMPROCS=2;",
        "export LIB_FGM_SRC=$WM_PROJECT_USER_DIR/applications/MyFGMFoam/src;",
        "export FGM_SOLVER_DIR=$WM_PROJECT_USER_DIR/applications/MyFGMFoam/applications/solver;",
        "Allwmake -j -s -q 2>&1 | tee allwmake.log"
      ],
      "args": [],
      "options": {},
      "problemMatcher": [],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },

    {
      "type": "shell",
      "label": "of-7: debug build MyFGMFoam",
      "command": [
        "cd ${workspaceFolder}/applications/MyFGMFoam/src;",
        "source /OpenFOAM/of7/OpenFOAM-7/etc/bashrc WM_NCOMPROCS=2;",
        "export WM_COMPILE_OPTION=Debug;",
        "export LIB_FGM_SRC=$WM_PROJECT_USER_DIR/applications/MyFGMFoam/src;",
        "export FGM_SOLVER_DIR=$WM_PROJECT_USER_DIR/applications/MyFGMFoam/applications/solver;",
        "Allwmake -j -s -q 2>&1 | tee allwmake.log"
      ],
      "args": [],
      "options": {},
      "problemMatcher": []
    },
  ],
  "version": "2.0.0"
}