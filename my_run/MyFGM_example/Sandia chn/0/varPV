FoamFile
{
    version     2.0;
    format      ascii;
    class       volScalarField;
    location    "0";
    object      varPV;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 0 0 0 0 0 0];

internalField   uniform 0;

boundaryField
{
	wall
    {
        type            zeroGradient;
    }
	outlet
    {
        type            zeroGradient;
    }
	sym_yz
    {
        type            symmetry;
    }
	sym_xz
    {
        type            symmetry;
    }
    inlet_air
    {
        type            fixedValue;
        value           uniform 0;
    }
	wall_inlet
    {
        type            zeroGradient;
    }
	inlet_fuel
    {
        type            fixedValue;
        value           uniform 0;
    }
}


